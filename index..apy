<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sleek Creator Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            background-color: #0b111e;
            color: #f3f4f6;
            font-family: system-ui, -apple-system, sans-serif;
        }
    </style>
</head>
<body class="p-4 max-w-md mx-auto min-h-screen flex flex-col justify-between">

    <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-4">
        <h1 class="text-lg font-bold tracking-wide text-gray-200 flex items-center gap-2">
            <i data-lucide="zap" class="w-5 h-5 text-blue-500"></i> Sleek Creator Pro
        </h1>
        <button class="text-gray-400 hover:text-white"><i data-lucide="more-vertical"></i></button>
    </div>

    <div class="bg-[#111827] border border-gray-800 rounded-xl p-4 mb-5 flex items-center justify-between shadow-lg">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg">G</div>
            <div>
                <h3 class="text-sm font-semibold text-gray-200">Creator Studio Pro</h3>
                <p class="text-xs text-gray-400">Session Remembered</p>
            </div>
        </div>
        <button onclick="clearSavedKey()" class="text-xs text-red-400 font-medium hover:underline">Clear Key</button>
    </div>

    <div class="mb-5">
        <h2 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-2">Workspace</h2>
        <div class="grid grid-cols-3 gap-3">
            <button id="mode-img" onclick="setMode('img')" class="border border-gray-800 bg-[#111827] p-4 rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer transition">
                <i data-lucide="image" class="w-5 h-5 text-gray-400"></i>
                <span class="text-xs text-gray-400">Img</span>
            </button>
            <button id="mode-vid" onclick="setMode('vid')" class="border-2 border-blue-500 bg-[#111827] p-4 rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer transition">
                <i data-lucide="video" class="w-5 h-5 text-blue-500"></i>
                <span class="text-xs text-white font-medium">Vid</span>
            </button>
            <button id="mode-txt" onclick="setMode('txt')" class="border border-gray-800 bg-[#111827] p-4 rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer transition">
                <i data-lucide="file-text" class="w-5 h-5 text-gray-400"></i>
                <span class="text-xs text-gray-400">Txt</span>
            </button>
        </div>
    </div>

    <div class="bg-[#111827] border border-gray-800 rounded-xl p-4 mb-5 space-y-4 shadow-md">
        <div>
            <label class="block text-xs font-semibold text-gray-400 mb-1">Gemini API Key (Auto-Saves)</label>
            <div class="relative">
                <input type="password" id="api-key" oninput="saveKeyAutomatically()" class="w-full bg-[#0b111e] border border-gray-800 rounded-lg py-2 pl-3 pr-10 text-sm focus:outline-none focus:border-blue-500 tracking-wider" placeholder="••••••••••••••••••••••••••••••••">
                <button onclick="toggleKeyVisibility()" class="absolute right-3 top-2.5 text-gray-500 hover:text-gray-300">
                    <i id="eye-icon" data-lucide="eye" class="w-4 h-4"></i>
                </button>
            </div>
            <a href="https://aistudio.google.com/" target="_blank" class="text-[11px] text-blue-400 mt-1 block hover:underline">[see how to get your GOOGLE GEMINI_API_KEY]</a>
        </div>

        <div>
            <label id="input-label" class="block text-xs font-semibold text-gray-400 mb-1">YouTube URL / Video ID</label>
            <input type="text" id="input-value" class="w-full bg-[#0b111e] border border-gray-800 rounded-lg p-2.5 text-sm focus:outline-none focus:border-blue-500" placeholder="https://youtu.be/...">
        </div>
    </div>

    <div class="mb-5">
        <h2 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-2">Tools</h2>
        <div class="grid grid-cols-3 gap-3">
            <button id="tool-trim" onclick="setTool('trim')" class="border border-gray-800 bg-[#111827] py-3 rounded-xl flex flex-col items-center justify-center gap-1.5 cursor-pointer">
                <i data-lucide="scissors" class="w-4 h-4 text-gray-400"></i>
                <span class="text-xs text-gray-400">Trim</span>
            </button>
            <button id="tool-repurpose" onclick="setTool('repurpose')" class="border-2 border-blue-500 bg-[#111827] py-3 rounded-xl flex flex-col items-center justify-center gap-1.5 cursor-pointer">
                <i data-lucide="refresh-cw" class="w-4 h-4 text-blue-500"></i>
                <span class="text-xs text-white font-medium">Repurpose</span>
            </button>
            <button id="tool-analyze" onclick="setTool('analyze')" class="border border-gray-800 bg-[#111827] py-3 rounded-xl flex flex-col items-center justify-center gap-1.5 cursor-pointer">
                <i data-lucide="search" class="w-4 h-4 text-gray-400"></i>
                <span class="text-xs text-gray-400">Analyze</span>
            </button>
        </div>
    </div>

    <div class="bg-[#111827] border border-gray-800 rounded-xl p-4 mb-6 shadow-md">
        <h2 class="text-xs font-bold text-gray-400 tracking-wider uppercase mb-2">Clip Feed</h2>
        <div class="relative bg-[#0b111e] border border-gray-800 rounded-lg p-4 flex flex-col items-center justify-center min-h-[160px] text-center">
            
            <div id="clip-feed-status" class="w-full">
                <div id="video-preview-btn" class="w-12 h-12 mx-auto bg-white/5 border border-white/10 rounded-full flex items-center justify-center mb-3 shadow-inner">
                    <i data-lucide="play" class="w-5 h-5 text-gray-300 fill-gray-300 ml-0.5"></i>
                </div>
                <h3 class="text-sm font-semibold text-gray-200">Prepared Content Asset</h3>
                <p class="text-xs text-gray-500">Ready to process sequence</p>
            </div>

        </div>
    </div>

    <button onclick="dispatchPipelineTask()" class="w-full bg-slate-700 hover:bg-slate-600 border border-slate-600 text-white font-semibold py-3.5 rounded-xl text-center cursor-pointer transition shadow-md tracking-wide">
        Process & Upload
    </button>

    <script>
        // Default Config Global States
        let currentMode = 'vid';
        let currentTool = 'repurpose';

        // Load saved API key on page load startup
        window.addEventListener('DOMContentLoaded', () => {
            const savedKey = localStorage.getItem('gemini_api_key');
            if (savedKey) {
                document.getElementById('api-key').value = savedKey;
            }
        });

        // Save key to phone storage as the user types
        function saveKeyAutomatically() {
            const keyVal = document.getElementById('api-key').value.trim();
            localStorage.setItem('gemini_api_key', keyVal);
        }

        // Wipe the saved key out if they want to reset it
        function clearSavedKey() {
            localStorage.removeItem('gemini_api_key');
            document.getElementById('api-key').value = '';
            alert("Saved Gemini API Key has been cleared.");
        }

        // Toggle Key Input mask behavior
        function toggleKeyVisibility() {
            const input = document.getElementById('api-key');
            const icon = document.getElementById('eye-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }

        // Toggle Workspace mode variables
        function setMode(mode) {
            currentMode = mode;
            const modes = ['img', 'vid', 'txt'];
            const label = document.getElementById('input-label');
            const inputField = document.getElementById('input-value');
            
            if(mode === 'vid') {
                label.innerText = 'YouTube URL / Video ID';
                inputField.placeholder = 'https://youtu.be/...';
            } else if(mode === 'txt') {
                label.innerText = 'Script Source Text';
                inputField.placeholder = 'Paste script details or copy lines here...';
            } else {
                label.innerText = 'Visual Creative Concept Layout Description';
                inputField.placeholder = 'Describe image framework prompt details...';
            }

            modes.forEach(m => {
                const btn = document.getElementById(`mode-${m}`);
                if(m === mode) {
                    btn.className = "border-2 border-blue-500 bg-[#111827] p-4 rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer transition";
                    btn.querySelector('i').className = "w-5 h-5 text-blue-500";
                    btn.querySelector('span').className = "text-xs text-white font-medium";
                } else {
                    btn.className = "border border-gray-800 bg-[#111827] p-4 rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer transition";
                    btn.querySelector('i').className = "w-5 h-5 text-gray-400";
                    btn.querySelector('span').className = "text-xs text-gray-400";
                }
            });
            lucide.createIcons();
        }

        // Toggle Selected Action tools
        function setTool(tool) {
            currentTool = tool;
            const tools = ['trim', 'repurpose', 'analyze'];
            tools.forEach(t => {
                const btn = document.getElementById(`tool-${t}`);
                if(t === tool) {
                    btn.className = "border-2 border-blue-500 bg-[#111827] py-3 rounded-xl flex flex-col items-center justify-center gap-1.5 cursor-pointer";
                    btn.querySelector('i').className = "w-4 h-4 text-blue-500";
                    btn.querySelector('span').className = "text-xs text-white font-medium";
                } else {
                    btn.className = "border border-gray-800 bg-[#111827] py-3 rounded-xl flex flex-col items-center justify-center gap-1.5 cursor-pointer";
                    btn.querySelector('i').className = "w-4 h-4 text-gray-400";
                    btn.querySelector('span').className = "text-xs text-gray-400";
                }
            });
            lucide.createIcons();
        }

        // Send data strictly to the Render backend, bypassing client-side API libraries entirely
        async function dispatchPipelineTask() {
            const apiKey = document.getElementById('api-key').value.trim();
            const inputValue = document.getElementById('input-value').value.trim();
            const clipFeed = document.getElementById('clip-feed-status');

            if (!apiKey) {
                alert("Please enter your Gemini API Key first.");
                return;
            }
            if (!inputValue) {
                alert("Please enter an input URL or script text.");
                return;
            }

            // Set loading status inside the Clip Feed dashboard card
            if (clipFeed) {
                clipFeed.innerHTML = `
                    <h3 class="text-sm font-semibold text-blue-400 animate-pulse">Processing pipeline request active...</h3>
                    <p class="text-xs text-gray-500 mt-1">Talking to backend cloud cluster server...</p>
                `;
            }

            try {
                // Network call targeting your Render backend API service endpoint
                const response = await fetch('https://shotify-x6x8.onrender.com/api/process', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        apiKey: apiKey,
                        inputValue: inputValue,
                        mode: currentMode,
                        tool: currentTool
                    })
                });

                const dataset = await response.json();

                if (response.ok) {
                    if (clipFeed) {
                        clipFeed.innerHTML = `
                            <div class="w-full text-left">
                                <h4 class="text-xs font-bold text-green-400 uppercase tracking-wide mb-1">✓ Sequence Finalized:</h4>
                                <div class="text-xs text-gray-300 leading-relaxed bg-[#111827] p-2.5 rounded border border-gray-800 max-h-48 overflow-y-auto whitespace-pre-wrap">${dataset.result}</div>
                            </div>
                        `;
                    }
                } else {
                    throw new Error(dataset.error || "Internal cloud operation error");
                }
            } catch (err) {
                alert("Task execution failed: " + err.message);
                if (clipFeed) {
                    clipFeed.innerHTML = `
                        <h3 class="text-sm font-semibold text-red-400">Task Failure Error Found</h3>
                        <p class="text-xs text-gray-500 mt-1">${err.message}</p>
                    `;
                }
            }
        }

        // Initialize UI Graphic Components
        lucide.createIcons();
    </script>
</body>
</html>
